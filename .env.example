# Operato WMS — 환경변수 예시
# 이 파일을 복사하여 .env 파일을 만들고 실제 값으로 채워주세요.
#   cp .env.example .env

# Jasypt 마스터 키 (application-prod.properties의 ENC(...) 복호화에 사용)
JASYPT_ENCRYPTOR_PASSWORD=your-strong-master-key

# PostgreSQL 컨테이너 초기화 패스워드 (docker-compose postgres 서비스 전용)
# ⚠️ 이 값은 application-prod.properties의 spring.datasource.password ENC() 복호화 값과 반드시 일치해야 합니다.
#    ENC() 값을 변경하거나 새로 암호화할 경우 여기도 동일하게 맞춰야 합니다.
DB_PASSWORD=your-db-password
