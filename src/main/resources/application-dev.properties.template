# ========================================
# 개발 모드 설정 (application-dev.properties)
# ========================================
# 사용법:
#   1. 이 파일을 application-dev.properties로 복사
#   2. 필요한 값 수정
#   3. -Dspring.profiles.active=dev 옵션으로 실행

# ========================================
# 프론트엔드 개발 모드 설정
# ========================================

# SPA Controller 비활성화 (프론트엔드는 별도 포트 3000에서 실행)
operato.wms.spa.enabled=false

# CORS 설정 (프론트엔드 개발 서버 허용)
spring.web.cors.allowed-origins=http://localhost:3000,http://127.0.0.1:3000
spring.web.cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS,PATCH
spring.web.cors.allowed-headers=*
spring.web.cors.allow-credentials=true
spring.web.cors.max-age=3600

# ========================================
# 데이터베이스 설정 (개발용)
# ========================================
# 실제 DB 정보로 변경하세요

# PostgreSQL
#spring.datasource.url=jdbc:postgresql://localhost:5432/operato_wms_dev
#spring.datasource.username=your_username
#spring.datasource.password=your_password

# MySQL
#spring.datasource.url=jdbc:mysql://localhost:3306/operato_wms_dev
#spring.datasource.username=your_username
#spring.datasource.password=your_password

# ========================================
# Redis 설정 (개발용)
# ========================================
#spring.data.redis.host=localhost
#spring.data.redis.port=6379

# ========================================
# 로깅 설정
# ========================================
logging.level.operato.wms=DEBUG
logging.level.org.springframework.web=DEBUG

# ========================================
# 개발 도구
# ========================================
spring.devtools.restart.enabled=true
management.endpoint.shutdown.enabled=true
