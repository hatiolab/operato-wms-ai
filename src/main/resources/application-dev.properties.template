# ========================================
# 개발 모드 설정 (application-dev.properties)
# ========================================
# 사용법:
#   1. 이 파일을 application-dev.properties로 복사
#   2. 필요한 값 수정
#   3. -Dspring.profiles.active=dev 옵션으로 실행

# ========================================
# 프론트엔드 개발 모드 설정
# ========================================

# SPA Controller 비활성화 (프론트엔드는 별도 포트에서 실행)
# 포트는 frontend/packages/operato-wes/config/config.development.js에서 설정 (기본: 5907)
operato.wms.spa.enabled=false

# CORS 설정 (프론트엔드 개발 서버 허용)
spring.web.cors.allowed-origins=http://localhost:5907,http://127.0.0.1:5907
spring.web.cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS,PATCH
spring.web.cors.allowed-headers=*
spring.web.cors.allow-credentials=true
spring.web.cors.max-age=3600

# ========================================
# 데이터베이스 설정 (개발용)
# ========================================
# 실제 DB 정보로 변경하세요

# PostgreSQL
#spring.datasource.url=jdbc:postgresql://localhost:5432/operato_wms_dev
#spring.datasource.username=your_username
#spring.datasource.password=your_password

# MySQL
#spring.datasource.url=jdbc:mysql://localhost:3306/operato_wms_dev
#spring.datasource.username=your_username
#spring.datasource.password=your_password

# ========================================
# Redis 설정 (개발용)
# ========================================
#spring.data.redis.host=localhost
#spring.data.redis.port=6379

# ========================================
# 로깅 설정
# ========================================
logging.level.operato.wms=DEBUG
logging.level.org.springframework.web=DEBUG

# ========================================
# AWS S3 파일 스토리지 설정
# ========================================
# storage_infos 테이블의 storage_type = 'S3' 인 Storage에서 사용
# storage_type = 'LOCAL' (기본값) 이면 이 설정은 무시됨

# 스토리지 타입 기본값 (LOCAL | S3)
#aws.s3.default-storage-type=LOCAL

# AWS 리전
#aws.s3.region=ap-northeast-2

# S3 버킷명
#aws.s3.bucket=my-wms-files

# 자격증명 방식 (credentials | instance-profile)
# - credentials: access-key / secret-key 직접 지정
# - instance-profile: EC2/ECS IAM Role 자동 사용 (운영 권장)
#aws.s3.auth-type=credentials

# Access Key (auth-type=credentials 일 때만 사용)
#aws.s3.access-key=YOUR_ACCESS_KEY_ID
#aws.s3.secret-key=YOUR_SECRET_ACCESS_KEY

# 다운로드 방식 (stream | presigned-url)
# - stream: 서버가 S3에서 읽어 클라이언트에 중계 (인증 파일용, 기본값)
# - presigned-url: 유효기간 있는 S3 URL로 redirect (공개 파일용)
#aws.s3.download-mode=stream

# Presigned URL 유효시간 (분, download-mode=presigned-url 일 때만 사용)
#aws.s3.presigned-url-expiry-minutes=60

# 커스텀 엔드포인트 (MinIO 등 S3 호환 서비스 사용 시, AWS 기본값이면 주석 처리)
#aws.s3.endpoint-url=http://localhost:9000

# Path-style 접근 방식 (MinIO 등 사용 시 true, AWS 기본값은 false)
# ※ 서명 오류 발생 시 true 로 변경해볼 것
#aws.s3.path-style-access=false

# ========================================
# 개발 도구
# ========================================
spring.devtools.restart.enabled=true
management.endpoint.shutdown.enabled=true
