{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(python3 *)",
      "Bash(pip3 install *)",
      "Bash(cd frontend && yarn *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Read(src/main/resources/application-dev.properties)",
      "Read(src/main/resources/application-prod.properties)",
      "Read(.env)"
    ],
    "additionalDirectories": [
      "../operato-wms-app",
      "../otarepo-core"
    ]
  },

  "env": {
    "JAVA_HOME": "/Library/Java/JavaVirtualMachines/temurin-18.jdk/Contents/Home",
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },

  "language": "korean"
}
