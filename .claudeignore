# =====================================================
# .claudeignore — Claude Code 토큰 절감을 위한 제외 목록
# =====================================================

# --- 빌드 아티팩트 ---
build/
.gradle/
*.class
*.jar
*.war

# --- 로그 ---
logs/
*.log

# --- Git 내부 ---
.git/

# --- 참조 문서 (바이너리/대용량) ---
ref/*.pptx
ref/*.pdf
ref/*.xlsx

# --- 운영/설계 문서 (작업 시 필요하면 명시적으로 참조) ---
docs/operations/
docs/design/
docs/architecture/
docs/quality/
docs/refactoring/
docs/roadmap/

# --- 작업 로그 (세션별 기록, 코딩 작업과 무관) ---
.ai/logs/

# --- 환경설정 민감 파일 ---
src/main/resources/application-dev.properties
src/main/resources/application-prod.properties

# --- 프론트엔드 빌드 산출물 및 의존성 ---
node_modules/
frontend/node_modules/
frontend/packages/*/node_modules/
frontend/packages/*/dist-app/
frontend/packages/*/dist-client/
frontend/packages/*/dist-server/
frontend/.yarn/
frontend/.pnp.*
frontend/yarn.lock
src/main/resources/static/

# --- 프론트엔드 템플릿 및 설정 파일 ---
frontend/templates/
frontend/.prettierrc
frontend/.eslintrc*
