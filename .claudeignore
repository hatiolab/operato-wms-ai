# =====================================================
# .claudeignore — Claude Code 토큰 절감을 위한 제외 목록
# =====================================================

# --- 빌드 아티팩트 ---
build/
.gradle/
*.class
*.jar
*.war

# --- 로그 ---
logs/
*.log

# --- Git 내부 ---
.git/

# --- 참조 문서 (바이너리/대용량) ---
ref/*.pptx
ref/*.pdf
ref/*.xlsx

# --- 운영/설계 문서 (작업 시 필요하면 명시적으로 참조) ---
docs/operations/
docs/design/
docs/architecture/
docs/quality/
docs/refactoring/
docs/roadmap/

# --- 작업 로그 (세션별 기록, 코딩 작업과 무관) ---
.ai/logs/

# --- 환경설정 민감 파일 ---
src/main/resources/application-dev.properties
src/main/resources/application-prod.properties
