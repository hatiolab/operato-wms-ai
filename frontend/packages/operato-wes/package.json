{
  "name": "@operato-app/operato-wes",
  "version": "7.0.52",
  "main": "dist-server/index.js",
  "browser": "dist-client/index.js",
  "things-factory": true,
  "license": "MIT",
  "author": "heartyoh",
  "description": "Cutting-Edge Warehouse Execution System by Operato",
  "publishConfig": {
    "access": "public",
    "@things-factory:registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hatiolab/things-factory.git",
    "directory": "packages/operato-wes"
  },
  "scripts": {
    "serve": "things-factory operato-wes",
    "serve:dev": "npm run build:server && concurrently -k -r \"npm run build:client:watch\" \"things-factory-dev operato-wes\"",
    "copy:files": "copyfiles -e \"./client/**/*.{ts,js,json}\" -u 1 \"./client/**/*\" dist-client",
    "build": "npm run build:server && npm run build:client",
    "build:client": "npm run clean:client && npm run copy:files && tsc --p ./client/tsconfig.json",
    "build:client:watch": "npm run copy:files && tsc --p ./client/tsconfig.json --watch --preserveWatchOutput",
    "build:server": "npm run clean:server && tsc --p ./server/tsconfig.json",
    "build:app": "npm run clean:app && webpack --config ../../node_modules/@things-factory/builder/webpack.config.js",
    "clean:server": "rimraf dist-server",
    "clean:client": "rimraf dist-client",
    "clean:app": "rimraf dist-app",
    "clean": "npm run clean:server && npm run clean:client",
    "migration": "npm run build:server && things-factory-migration",
    "migration:privileges": "npm run build:server && things-factory-migration-privileges",
    "migration:create": "node ../../node_modules/typeorm/cli.js migration:create -d ./server/migrations",
    "migration:generate": "node ../../node_modules/typeorm/cli.js migration:generate",
    "migration:run": "node ../../node_modules/typeorm/cli.js migration:run",
    "migration:revert": "node ../../node_modules/typeorm/cli.js migration:revert",
    "stop:dev": "kill $(lsof -t -i:3000,3001)",
    "stop": "things-factory-stop operato-wes",
    "docker": "npm run build:app && things-factory-dockerize hatiolab/wms-client:latest  hatiolab/wms-client:$npm_package_version linux/amd64",
    "docker:run": "docker run --platform linux/amd64 -p 4000:5907 hatiolab/wms-client:latest",
    "docker:push": "docker image push hatiolab/wms-client:latest && docker image push hatiolab/wms-client:$npm_package_version"
  },
  "dependencies": {
    "@material/web": "^2.0.0",
    "@operato-app/metapage": "^7.0.49",
    "@operato-app/operato-logis-system-ui": "^7.0.49",
    "@operato-app/operatofill": "^7.0.49",
    "@operato/barcode": "^7.0.0",
    "@operato/board": "^7.0.0",
    "@operato/data-grist": "^7.0.0",
    "@operato/font": "^7.0.0",
    "@operato/ghost-print": "^7.0.0",
    "@operato/graphql": "^7.0.0",
    "@operato/i18n": "^7.0.0",
    "@operato/layout": "^7.0.0",
    "@operato/p13n": "^7.0.0",
    "@operato/popup": "^7.0.0",
    "@operato/property-editor": "^7.0.0",
    "@operato/pull-to-refresh": "^7.0.0",
    "@operato/shell": "^7.0.0",
    "@operato/styles": "^7.0.0",
    "@operato/utils": "^7.0.0",
    "@things-factory/api": "^7.0.0",
    "@things-factory/apptool-ui": "^7.0.0",
    "@things-factory/attachment-base": "^7.0.0",
    "@things-factory/auth-ui": "^7.0.0",
    "@things-factory/barcode-base": "^7.0.0",
    "@things-factory/barcode-ui": "^7.0.0",
    "@things-factory/code-ui": "^7.0.0",
    "@things-factory/context-ui": "^7.0.0",
    "@things-factory/evaluation": "^7.0.0",
    "@things-factory/export-ui": "^7.0.0",
    "@things-factory/export-ui-excel": "^7.0.0",
    "@things-factory/help": "^7.0.0",
    "@things-factory/import-ui": "^7.0.0",
    "@things-factory/import-ui-excel": "^7.0.0",
    "@things-factory/lite-menu": "^7.0.0",
    "@things-factory/more-ui": "^7.0.0",
    "@things-factory/notification": "^7.0.0",
    "@things-factory/print-ui": "^7.0.0",
    "@things-factory/resource-ui": "^7.0.0",
    "@things-factory/routing-base": "^7.0.0",
    "@things-factory/setting-ui": "^7.0.0",
    "@things-factory/shell": "^7.0.0",
    "@things-factory/system": "^7.0.0",
    "chart.js": "^4.4.1"
  },
  "devDependencies": {
    "@things-factory/builder": "^7.0.0",
    "@types/node": "^18.11.18",
    "plop": "^3.0.5"
  },
  "gitHead": "4071a1ba7f1c924b0a01d76246f63a5b94680319"
}